---
import Layout from '../layouts/Layout.astro';
import { content } from '../data/content';

const c = content;
---

<Layout title={c.meta.title.zh}>
  <!-- Hero -->
  <header class="hero fade-in">
    <img src="/images/photo.jpg" alt="任小为" class="hero-photo" width="120" height="120" />
    <h1 class="hero-name" data-lang="zh">{c.hero.name.zh}</h1>
    <h1 class="hero-name" data-lang="en">{c.hero.name.en}</h1>
    <p class="hero-tagline" data-lang="zh">{c.hero.tagline.zh}</p>
    <p class="hero-tagline" data-lang="en">{c.hero.tagline.en}</p>
    <div class="hero-contact">
      <span>&#9742; {c.contact.phone}</span>
      <span>&#9993; {c.contact.email}</span>
      <span data-lang="zh">&#9962; {c.contact.location.zh}</span>
      <span data-lang="en">&#9962; {c.contact.location.en}</span>
    </div>
    <div class="hero-contact" style="margin-top:10px">
      <span data-lang="zh">&#127891; {c.contact.school.zh}</span>
      <span data-lang="en">&#127891; {c.contact.school.en}</span>
    </div>
  </header>

  <!-- About -->
  <section class="section fade-in">
    <h2 class="section-title" data-lang="zh">{c.about.title.zh}</h2>
    <h2 class="section-title" data-lang="en">{c.about.title.en}</h2>
    <p class="about-text" data-lang="zh">{c.about.text.zh}</p>
    <p class="about-text" data-lang="en">{c.about.text.en}</p>
  </section>

  <!-- Education -->
  <section class="section fade-in">
    <h2 class="section-title" data-lang="zh">{c.education.title.zh}</h2>
    <h2 class="section-title" data-lang="en">{c.education.title.en}</h2>
    {c.education.items.map(item => (
      <div class="timeline-item">
        <div class="timeline-header">
          <span class="timeline-title" data-lang="zh">{item.school.zh}</span>
          <span class="timeline-title" data-lang="en">{item.school.en}</span>
          <span class="timeline-period">{item.period}</span>
        </div>
        <div class="timeline-subtitle" data-lang="zh">{item.major.zh} · {item.location.zh}</div>
        <div class="timeline-subtitle" data-lang="en">{item.major.en} · {item.location.en}</div>
        <ul class="timeline-details">
          <li data-lang="zh">{item.details.zh}</li>
          <li data-lang="en">{item.details.en}</li>
        </ul>
      </div>
    ))}
  </section>

  <!-- Experience -->
  <section class="section fade-in">
    <h2 class="section-title" data-lang="zh">{c.experience.title.zh}</h2>
    <h2 class="section-title" data-lang="en">{c.experience.title.en}</h2>
    {c.experience.items.map(item => (
      <div class="timeline-item">
        <div class="timeline-header">
          <span class="timeline-title">{item.company.zh} / {item.company.en}</span>
          <span class="timeline-period">{item.period}</span>
        </div>
        <div class="timeline-subtitle" data-lang="zh">{item.role.zh} · {item.industry.zh} · {item.location.zh}</div>
        <div class="timeline-subtitle" data-lang="en">{item.role.en} · {item.industry.en} · {item.location.en}</div>
        <ul class="timeline-details">
          {item.bullets.zh.map((b, i) => (
            <li data-lang="zh">{b}</li>
          ))}
          {item.bullets.en.map((b, i) => (
            <li data-lang="en">{b}</li>
          ))}
        </ul>
      </div>
    ))}
  </section>

  <!-- Projects -->
  <section class="section fade-in">
    <h2 class="section-title" data-lang="zh">{c.projects.title.zh}</h2>
    <h2 class="section-title" data-lang="en">{c.projects.title.en}</h2>
    {c.projects.items.map(item => (
      <div class="project-card">
        <div class="timeline-item" style="margin-bottom:12px">
          <div class="timeline-header">
            <span class="timeline-title">{typeof item.name === 'string' ? item.name : item.name.zh} / {typeof item.name === 'string' ? item.name : item.name.en}</span>
            <span class="timeline-period" data-lang="zh">{item.period.zh}</span>
            <span class="timeline-period" data-lang="en">{item.period.en}</span>
          </div>
          <div class="timeline-subtitle" data-lang="zh">{item.role.zh} · {item.context.zh} · {item.location.zh}</div>
          <div class="timeline-subtitle" data-lang="en">{item.role.en} · {item.context.en} · {item.location.en}</div>
          <ul class="timeline-details">
            {item.bullets.zh.map(b => (<li data-lang="zh">{b}</li>))}
            {item.bullets.en.map(b => (<li data-lang="en">{b}</li>))}
          </ul>
          {'link' in item && item.link && (
            <a class="project-link" href={item.link.url} target="_blank" rel="noopener">
              {item.link.label.zh} / {item.link.label.en} &rarr;
            </a>
          )}
        </div>
        {item.screenshots.length > 0 && (
          <div class="project-screenshots">
            {item.screenshots.map(src => (<img src={src} alt="" loading="lazy" />))}
          </div>
        )}
      </div>
    ))}
  </section>

  <!-- Leadership -->
  <section class="section fade-in">
    <h2 class="section-title" data-lang="zh">{c.leadership.title.zh}</h2>
    <h2 class="section-title" data-lang="en">{c.leadership.title.en}</h2>
    {c.leadership.items.map(item => (
      <div class="timeline-item">
        <div class="timeline-header">
          <span class="timeline-title" data-lang="zh">{item.org.zh}</span>
          <span class="timeline-title" data-lang="en">{item.org.en}</span>
          <span class="timeline-period">{item.period}</span>
        </div>
        <div class="timeline-subtitle" data-lang="zh">{item.role.zh} · {item.location.zh}</div>
        <div class="timeline-subtitle" data-lang="en">{item.role.en} · {item.location.en}</div>
        <ul class="timeline-details">
          {item.bullets.zh.map(b => (<li data-lang="zh">{b}</li>))}
          {item.bullets.en.map(b => (<li data-lang="en">{b}</li>))}
        </ul>
      </div>
    ))}
  </section>

  <!-- Academic -->
  <section class="section fade-in">
    <h2 class="section-title" data-lang="zh">{c.academic.title.zh}</h2>
    <h2 class="section-title" data-lang="en">{c.academic.title.en}</h2>
    <div class="timeline-item">
      <div class="timeline-header">
        <span class="timeline-title" data-lang="zh">{c.academic.project.zh}</span>
        <span class="timeline-title" data-lang="en">{c.academic.project.en}</span>
        <span class="timeline-period">{c.academic.period}</span>
      </div>
      <div class="timeline-subtitle" data-lang="zh">{c.academic.context.zh}</div>
      <div class="timeline-subtitle" data-lang="en">{c.academic.context.en}</div>
      <ul class="timeline-details">
        {c.academic.bullets.zh.map(b => (<li data-lang="zh">{b}</li>))}
        {c.academic.bullets.en.map(b => (<li data-lang="en">{b}</li>))}
      </ul>
    </div>
  </section>

  <!-- Awards -->
  <section class="section fade-in">
    <h2 class="section-title" data-lang="zh">{c.awards.title.zh}</h2>
    <h2 class="section-title" data-lang="en">{c.awards.title.en}</h2>
    {c.awards.items.map(item => (
      <div class="award-item">
        <span data-lang="zh">{item.name.zh}</span>
        <span data-lang="en">{item.name.en}</span>
        <span class="award-year">{item.year}</span>
      </div>
    ))}
  </section>

  <!-- Skills -->
  <section class="section fade-in">
    <h2 class="section-title" data-lang="zh">{c.skills.title.zh}</h2>
    <h2 class="section-title" data-lang="en">{c.skills.title.en}</h2>
    {c.skills.groups.map(group => (
      <div class="skill-group">
        <span class="skill-label" data-lang="zh">{group.label.zh}</span>
        <span class="skill-label" data-lang="en">{group.label.en}</span>
        {group.tags.map(tag => (
          <span class="skill-tag">{typeof tag === 'string' ? tag : tag.zh}<span data-lang="en" style="display:none">{typeof tag === 'string' ? '' : ' / ' + tag.en}</span></span>
        ))}
      </div>
    ))}
  </section>

  <!-- Footer -->
  <footer class="footer fade-in">
    <p data-lang="zh">{c.footer.copyright.zh}</p>
    <p data-lang="en">{c.footer.copyright.en}</p>
  </footer>
</Layout>
