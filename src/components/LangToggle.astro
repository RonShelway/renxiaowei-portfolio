<div class="lang-toggle">
  <button class="lang-btn" onclick="setLang(window.currentLang === 'zh' ? 'en' : 'zh')">EN</button>
</div>
<script>
  (window as any).currentLang = localStorage.getItem('lang') || 'zh';
  const btn = document.querySelector('.lang-btn') as HTMLElement;
  if (btn) btn.textContent = (window as any).currentLang === 'zh' ? 'EN' : '中';
</script>
