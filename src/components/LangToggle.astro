<div class="lang-toggle">
  <button class="lang-btn" onclick="window.setLang(window.__lang === 'zh' ? 'en' : 'zh')">EN</button>
</div>
<script>
  window.__lang = localStorage.getItem('lang') || 'zh';
  const btn = document.querySelector('.lang-btn') as HTMLElement;
  if (btn) btn.textContent = window.__lang === 'zh' ? 'EN' : '中';
</script>
