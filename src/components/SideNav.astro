<script>
  (function() {
    const navItems = document.querySelectorAll('.nav-item');
    const sections = new Map<string, HTMLElement>();
    navItems.forEach(item => {
      const target = item.getAttribute('data-target');
      if (target) {
        const el = document.getElementById(target);
        if (el) sections.set(target, el);
      }
    });

    // Lang update — show correct label
    function updateNavLabels(lang: string) {
      navItems.forEach(item => {
        const labels = item.querySelectorAll('.nav-label');
        labels.forEach((lbl: Element) => {
          const elLang = lbl.getAttribute('data-lang');
          (lbl as HTMLElement).style.display = elLang === lang ? '' : 'none';
        });
      });
    }

    const currentLang = (window as any).__lang || localStorage.getItem('lang') || 'zh';
    updateNavLabels(currentLang);

    // Listen for lang changes from Layout.astro
    const origSetLang = (window as any).setLang;
    if (origSetLang) {
      (window as any).setLang = function(lang: string) {
        origSetLang(lang);
        updateNavLabels(lang);
        navItems.forEach(item => {
          item.setAttribute('title', item.getAttribute('data-' + lang) || '');
        });
      };
    }

    // Set initial titles
    navItems.forEach(item => {
      item.setAttribute('title', item.getAttribute('data-' + currentLang) || '');
    });

    // Intersection Observer for active tracking
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        const navItem = document.querySelector(`[data-target="${entry.target.id}"]`);
        if (navItem) {
          if (entry.isIntersecting) {
            navItems.forEach(ni => ni.classList.remove('active'));
            navItem.classList.add('active');
          }
        }
      });
    }, {
      rootMargin: '-20% 0px -60% 0px',
      threshold: 0,
    });

    sections.forEach(section => observer.observe(section));

    // Click — smooth scroll
    navItems.forEach(item => {
      item.addEventListener('click', (e) => {
        e.preventDefault();
        const target = item.getAttribute('data-target');
        if (target) {
          const el = document.getElementById(target);
          if (el) {
            el.scrollIntoView({ behavior: 'smooth', block: 'start' });
          }
        }
      });
    });
  })();
</script>

