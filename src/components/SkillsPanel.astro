<aside class="skills-panel-wrap" aria-label="Skills">
  <div class="card card-skills skills-panel-card">
    <div class="pushpin"></div>
    <div class="card-index">No. 008</div>
    <h2 class="section-title" data-lang="zh">技能</h2>
    <h2 class="section-title" data-lang="en">Skills</h2>
    <div id="skills-panel-groups"></div>
  </div>
</aside>

<script>
  const skillsData = {
    zh: {
      title: '技能',
      groups: [
        { label: '产品工具', tags: ['Figma', '墨刀', 'PRD'] },
        { label: 'AI 能力', tags: ['大模型原理', 'Agent 应用', 'AI 工作流'] },
        { label: '数据分析', tags: ['Python', 'SQL', 'PowerBI'] },
        { label: '开发基础', tags: ['Java', 'C/C++'] },
        { label: '语言能力', tags: ['IELTS 7.5', 'CET-6 637', '听说读写流利'] },
      ],
    },
    en: {
      title: 'Skills',
      groups: [
        { label: 'Product', tags: ['Figma', 'Mockplus', 'PRD'] },
        { label: 'AI', tags: ['LLM Principles', 'Agent Workflows', 'AI Automation'] },
        { label: 'Data', tags: ['Python', 'SQL', 'PowerBI'] },
        { label: 'Dev', tags: ['Java', 'C/C++'] },
        { label: 'Languages', tags: ['IELTS 7.5', 'CET-6 637', 'Fluent English'] },
      ],
    },
  };

  function renderSkills(lang: string) {
    const container = document.getElementById('skills-panel-groups');
    if (!container) return;
    const data = lang === 'en' ? skillsData.en : skillsData.zh;
    container.innerHTML = data.groups.map(g =>
      `<div class="skill-group">
        <span class="skill-label">${g.label}</span>
        ${g.tags.map(t => `<span class="skill-tag">${t}</span>`).join('')}
      </div>`
    ).join('');
  }

  const currentLang = (window as any).__lang || localStorage.getItem('lang') || 'zh';
  renderSkills(currentLang);

  const origSetLang = (window as any).setLang;
  if (origSetLang) {
    (window as any).setLang = function(lang: string) {
      origSetLang(lang);
      renderSkills(lang);
    };
  }
</script>

<style>
  .skills-panel-wrap {
    position: fixed;
    right: 28px;
    top: 50%;
    transform: translateY(-50%);
    width: 210px;
    max-height: 78vh;
    overflow-y: auto;
    z-index: 90;
  }

  .skills-panel-card {
    transform: none !important;
    margin-bottom: 0 !important;
    padding: 28px 20px 22px;
  }

  .skills-panel-card:hover {
    transform: translateY(-4px) !important;
  }

  /* Scrollbar */
  .skills-panel-wrap::-webkit-scrollbar { width: 4px; }
  .skills-panel-wrap::-webkit-scrollbar-track { background: transparent; }
  .skills-panel-wrap::-webkit-scrollbar-thumb { background: #D8D0C0; border-radius: 2px; }
  [data-theme="night"] .skills-panel-wrap::-webkit-scrollbar-thumb { background: #4D4838; }

  /* Mobile hide */
  @media (max-width: 1024px) {
    .skills-panel-wrap { display: none; }
  }
</style>
