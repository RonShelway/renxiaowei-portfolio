<aside class="skills-panel" aria-label="Skills">
  <div class="skills-panel-pin"></div>
  <h3 class="skills-panel-title" data-lang="zh">技能</h3>
  <h3 class="skills-panel-title" data-lang="en">Skills</h3>
  <div class="skills-panel-groups" id="skills-panel-groups">
    <!-- Populated by JS from content.ts data -->
  </div>
</aside>

<script>
  // Skills data — mirrored from content.ts so this component is self-contained
  const skillsData = {
    zh: {
      title: '技能',
      groups: [
        { label: '产品工具', tags: ['Figma', '墨刀', 'PRD'] },
        { label: 'AI 能力', tags: ['大模型原理', 'Agent 应用', 'AI 工作流'] },
        { label: '数据分析', tags: ['Python', 'SQL', 'PowerBI'] },
        { label: '开发基础', tags: ['Java', 'C/C++'] },
        { label: '语言能力', tags: ['IELTS 7.5', 'CET-6 637', '听说读写流利'] },
      ],
    },
    en: {
      title: 'Skills',
      groups: [
        { label: 'Product', tags: ['Figma', 'Mockplus', 'PRD'] },
        { label: 'AI', tags: ['LLM Principles', 'Agent Workflows', 'AI Automation'] },
        { label: 'Data', tags: ['Python', 'SQL', 'PowerBI'] },
        { label: 'Dev', tags: ['Java', 'C/C++'] },
        { label: 'Languages', tags: ['IELTS 7.5', 'CET-6 637', 'Fluent English'] },
      ],
    },
  };

  function renderSkills(lang: string) {
    const container = document.getElementById('skills-panel-groups');
    if (!container) return;
    const data = lang === 'en' ? skillsData.en : skillsData.zh;
    container.innerHTML = data.groups.map(g =>
      `<div class="sp-group">
        <span class="sp-label">${g.label}</span>
        <div class="sp-tags">${g.tags.map(t => `<span class="sp-tag">${t}</span>`).join('')}</div>
      </div>`
    ).join('');
  }

  const currentLang = (window as any).__lang || localStorage.getItem('lang') || 'zh';
  renderSkills(currentLang);

  // Update on lang change
  const origSetLang = (window as any).setLang;
  if (origSetLang) {
    (window as any).setLang = function(lang: string) {
      origSetLang(lang);
      renderSkills(lang);
    };
  }
</script>

